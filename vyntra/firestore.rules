rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny Rule
    match /{document=**} {
      allow read, write: if false;
    }

    // OTP Rules - Read MUST BE false, Write MUST BE false (managed server-side only)
    match /otps/{otpId} {
      allow read, write: if false;
    }

    // User Profile Rules - Read any
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Posts Rules - Read any authenticated, Create/Update/Delete only owner
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Follow Rules - Read any authenticated, Create/Delete only authenticated owner
    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.followerId == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null && resource.data.followerId == request.auth.uid;
    }

    // Likes Rules - Read any authenticated, Create/Delete only owner
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Communities Rules - Read any authenticated, Create/Modify if creator
    match /communities/{communityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.creatorId == request.auth.uid;
      allow delete: if false;
    }

    // Security Logs - Read only owner, Create only authenticated, Update/Delete false
    match /security_logs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
